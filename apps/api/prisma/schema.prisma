generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
  debts        Debt[]
  goals        Goal[]
  projects     Project[]
  tasks        Task[]
  habits       Habit[]
  habitLogs    HabitLog[]
}

model Transaction {
  id          String          @id @default(cuid())
  description String
  category    String
  amount      Float
  type        TransactionType
  account     AccountType     @default(CHECKING)
  date        DateTime
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())

  @@index([userId, date])
}

model Debt {
  id          String    @id @default(cuid())
  description String
  totalAmount Float
  paidAmount  Float     @default(0)
  dueDate     DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Goal {
  id            String    @id @default(cuid())
  name          String
  description   String?
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Project {
  id            String        @id @default(cuid())
  name          String
  description   String?
  status        ProjectStatus @default(IDEA)
  expectedValue Float?
  receivedValue Float         @default(0)
  priority      Priority      @default(MEDIUM)
  deadline      DateTime?
  nextAction    String?
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Task {
  id       String     @id @default(cuid())
  title    String
  notes    String?
  status   TaskStatus @default(TODAY)
  priority Priority   @default(MEDIUM)
  deadline DateTime?
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Habit {
  id        String     @id @default(cuid())
  name      String
  icon      String?
  order     Int        @default(0)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs      HabitLog[]
  createdAt DateTime   @default(now())
}

model HabitLog {
  id      String   @id @default(cuid())
  habitId String
  habit   Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date    DateTime

  @@unique([habitId, date])
  @@index([userId, date])
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum AccountType {
  CHECKING
  RESERVE
  HOUSE_FUND
}

enum ProjectStatus {
  IDEA
  WAITING
  IN_PROGRESS
  DONE
  PAID
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODAY
  DOING
  DONE
}

model Quote {
  id     String  @id @default(cuid())
  text   String
  author String?
}
